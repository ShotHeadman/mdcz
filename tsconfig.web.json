{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": [
    "apps/desktop/src/renderer/src/**/*.ts",
    "apps/desktop/src/renderer/src/**/*.tsx",
    "apps/desktop/src/renderer/src/**/*.d.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/vite.config.ts",
    "packages/client/**/*.ts",
    "packages/shared/**/*.ts"
  ],
  "exclude": ["packages/**/*.test.ts"]
}
